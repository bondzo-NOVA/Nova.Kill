local ESP_COLOR = Color3.fromRGB(210, 150, 255) -- same for box & skeleton & tracers
local function updateBoxESP()
    for _, plr in Players:GetPlayers() do
        if plr == Player then continue end
        local data = espBoxes[plr] or {}
        if not data.box then
            data.box = Drawing.new("Square")
            data.box.Thickness = 1.6
            data.box.Color = ESP_COLOR
            data.box.Transparency = 0.9
            data.box.Filled = false
           
            data.bg = Drawing.new("Square")
            data.bg.Thickness = 1
            data.bg.Color = Color3.fromRGB(30,30,30)
            data.bg.Transparency = 0.5
            data.bg.Filled = true
           
            data.bar = Drawing.new("Square")
            data.bar.Thickness = 1
            data.bar.Transparency = 0.3
            data.bar.Filled = true
           
            espBoxes[plr] = data
        end
       
        if boxEspEnabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") then
            local root = plr.Character.HumanoidRootPart
            local head = plr.Character.Head
            local hum = plr.Character:FindFirstChild("Humanoid")
            local rootPos, onScr = camera:WorldToViewportPoint(root.Position)
            if onScr then
                local hPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.7,0))
                local fPos = camera:WorldToViewportPoint(root.Position - Vector3.new(0,4,0))
                local height = math.abs(hPos.Y - fPos.Y)
                local width = height * 0.52
               
                data.box.Size = Vector2.new(width, height)
                data.box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
                data.box.Visible = true
               
                if hum then
                    local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    data.bg.Size = Vector2.new(width, 5)
                    data.bg.Position = Vector2.new(rootPos.X - width/2, rootPos.Y + height/2 + 3)
                    data.bg.Visible = true
                    data.bar.Size = Vector2.new(width * pct, 5)
                    data.bar.Position = data.bg.Position
                    data.bar.Color = Color3.fromHSV(pct * 0.33, 0.9, 0.9)
                    data.bar.Visible = true
                end
            else
                data.box.Visible = false
                data.bg.Visible = false
                data.bar.Visible = false
            end
        else
            data.box.Visible = false
            data.bg.Visible = false
            data.bar.Visible = false
        end
    end
end
local skeletonParts = {
    {"Head","UpperTorso"}, {"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"}, {"LeftUpperArm","LeftLowerArm"}, {"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"}, {"RightUpperArm","RightLowerArm"}, {"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"}, {"LeftUpperLeg","LeftLowerLeg"}, {"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"}, {"RightUpperLeg","RightLowerLeg"}, {"RightLowerLeg","RightFoot"}
}
local function updateSkeleton()
    for _, plr in Players:GetPlayers() do
        if plr == Player then continue end
        local entry = skeletons[plr] or {lines = {}}
        if #entry.lines == 0 then
            for _ in skeletonParts do
                local main = Drawing.new("Line")
                main.Color = ESP_COLOR -- same color as box
                main.Thickness = 2.2
                main.Transparency = 0.75
                main.Visible = false
               
                local glow = Drawing.new("Line")
                glow.Color = Color3.fromRGB(180, 120, 255) -- slight glow variant
                glow.Thickness = 4.5
                glow.Transparency = 0.92
                glow.Visible = false
               
                table.insert(entry.lines, {main = main, glow = glow})
            end
            skeletons[plr] = entry
        end
       
        if not skeletonEspEnabled or not plr.Character or not plr.Character:FindFirstChild("Head") then
            for _, pair in entry.lines do
                pair.main.Visible = false
                pair.glow.Visible = false
            end
            continue
        end
       
        local head = plr.Character.Head
        local visible = isTargetVisible(head)
        local anyOnScreen = false
       
        for i, pair in ipairs(skeletonParts) do
            local partA = plr.Character:FindFirstChild(pair[1])
            local partB = plr.Character:FindFirstChild(pair[2])
            if not partA or not partB then
                entry.lines[i].main.Visible = false
                entry.lines[i].glow.Visible = false
                continue
            end
           
            local posA, onScreenA = camera:WorldToViewportPoint(partA.Position)
            local posB, onScreenB = camera:WorldToViewportPoint(partB.Position)
           
            if onScreenA and onScreenB then
                local vecA = Vector2.new(posA.X, posA.Y)
                local vecB = Vector2.new(posB.X, posB.Y)
               
                entry.lines[i].glow.From = vecA
                entry.lines[i].glow.To = vecB
                entry.lines[i].glow.Visible = true
               
                entry.lines[i].main.From = vecA
                entry.lines[i].main.To = vecB
                entry.lines[i].main.Visible = true
                entry.lines[i].main.Transparency = 0.75 -- Fixed: no dim through walls
               
                anyOnScreen = true
            else
                entry.lines[i].main.Visible = false
                entry.lines[i].glow.Visible = false
            end
        end
       
        if not anyOnScreen then
            for _, pair in entry.lines do
                pair.main.Visible = false
                pair.glow.Visible = false
            end
        end
    end
end
local function updateTracers()
    for _, plr in Players:GetPlayers() do
        if plr == Player then continue end
        local data = tracers[plr] or {}
        if not data.line then
            data.line = Drawing.new("Line")
            data.line.Color = ESP_COLOR
            data.line.Thickness = 1.5
            data.line.Transparency = 0.8
            data.line.Visible = false
            tracers[plr] = data
        end
       
        if tracersEnabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local rootPos, onScr = camera:WorldToViewportPoint(root.Position)
            if onScr then
                local from = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y) -- bottom center
                local to = Vector2.new(rootPos.X, rootPos.Y)
                data.line.From = from
                data.line.To = to
                data.line.Visible = true
            else
                data.line.Visible = false
            end
        else
            data.line.Visible = false
        end
    end
end
-- ──── Fly & NoClip ─────────────────────────────────────────────────────────
local function toggleFly(on)
    flyEnabled = on
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
    local root = Character.HumanoidRootPart
    if on then
        flyBV = Instance.new("BodyVelocity", root)
        flyBV.MaxForce = Vector3.new(1e9,1e9,1e9)
        flyBV.Velocity = Vector3.zero
        flyConn = RunService.RenderStepped:Connect(function()
            local dir = Vector3.zero
            local cf = camera.CFrame
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.yAxis end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.yAxis end
            flyBV.Velocity = dir.Unit * flySpeed * (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 2.5 or 1)
        end)
    else
        if flyConn then flyConn:Disconnect() flyConn = nil end
        if flyBV then flyBV:Destroy() flyBV = nil end
    end
end
local function toggleNoClip(on)
    noClipEnabled = on
    if noclipConn then noclipConn:Disconnect() noclipConn = nil end
    if on then
        noclipConn = RunService.Stepped:Connect(function()
            if Character then
                for _, p in Character:GetDescendants() do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    end
end
-- ──── Spin Bot ─────────────────────────────────────────────────────────────
local function toggleSpinbot(on)
    spinbotEnabled = on
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
    local root = Character.HumanoidRootPart
    if on then
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.Parent = root
        bodyGyro.MaxTorque = Vector3.new(0, math.huge, 0)
        bodyGyro.P = 10000
        bodyGyro.D = 0
        bodyGyro.CFrame = root.CFrame
        spinConn = RunService.RenderStepped:Connect(function()
            bodyGyro.CFrame = bodyGyro.CFrame * CFrame.Angles(0, math.rad(spinSpeed), 0) -- Use variable speed
        end)
    else
        if spinConn then spinConn:Disconnect() spinConn = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
    end
end
