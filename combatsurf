-- ──── 3rd Person Toggle ────────────────────────────────────────────────────
local yaw = 0
local pitch = 0
local function toggleThirdPerson(on)
    thirdPersonEnabled = on
    if on then
        camera.CameraType = Enum.CameraType.Scriptable
        yaw = 0
        pitch = 0
        local lastMousePos = UserInputService:GetMouseLocation()
        inputConn = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - lastMousePos
                yaw = yaw - delta.X * 0.002
                pitch = pitch - delta.Y * 0.002
                pitch = math.clamp(pitch, -math.pi/2 + 0.1, math.pi/2 - 0.1)
                lastMousePos = input.Position
            end
        end)
        thirdPersonConn = RunService.RenderStepped:Connect(function()
            if Character and Character:FindFirstChild("HumanoidRootPart") then
                local root = Character.HumanoidRootPart
                local camCF = CFrame.new(root.Position) * CFrame.Angles(0, yaw, 0) * CFrame.Angles(pitch, 0, 0)
                local camPos = camCF.Position - camCF.LookVector * 8 + camCF.UpVector * 1
                camera.CFrame = CFrame.lookAt(camPos, root.Position)
            end
        end)
    else
        if inputConn then inputConn:Disconnect() inputConn = nil end
        if thirdPersonConn then thirdPersonConn:Disconnect() thirdPersonConn = nil end
        camera.CameraType = Enum.CameraType.Custom
    end
end
-- ──── Aimbot ───────────────────────────────────────────────────────────────
local aimConn
local function toggleAimbotSystem(on)
    aimbotEnabled = on
    hardFovCircle.Visible = on and not softAimbotEnabled
    softFovCircle.Visible = on and softAimbotEnabled
    if aimConn then aimConn:Disconnect() aimConn = nil end
    if on then
        aimConn = RunService.RenderStepped:Connect(function()
            if not holdingAim then return end
            local mousePos = UserInputService:GetMouseLocation()
            local closestHard, distHard = nil, hardAimFov + 1
            local closestSoft, distSoft = nil, softAimFov + 1
            local hardHead, softHead = nil, nil
            for _, p in Players:GetPlayers() do
                if p == Player or not p.Character or not p.Character:FindFirstChild("Head") then continue end
                local head = p.Character.Head
                local screen, onScr = camera:WorldToViewportPoint(head.Position)
                if onScr and isTargetVisible(head) then
                    local dist = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
                    if dist < distHard then
                        distHard = dist
                        closestHard = p
                        hardHead = head
                    end
                    if dist < distSoft then
                        distSoft = dist
                        closestSoft = p
                        softHead = head
                    end
                end
            end
            -- Hard aimbot (snap)
            if closestHard and hardHead and aimbotEnabled and not softAimbotEnabled then
                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, hardHead.Position)
            end
            -- Soft aimbot (smooth)
            if closestSoft and softHead and softAimbotEnabled then
                local targetCF = CFrame.lookAt(camera.CFrame.Position, softHead.Position)
                camera.CFrame = camera.CFrame:Lerp(targetCF, softSmoothing)
            end
            -- TriggerBot
            if triggerbotEnabled then
                local targetHead = softHead or hardHead
                if targetHead then
                    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
                    local aimPos = camera:WorldToViewportPoint(targetHead.Position)
                    local dev = (Vector2.new(aimPos.X, aimPos.Y) - center).Magnitude
                    if dev <= 18 then
                        VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
                        task.wait(0.006 + math.random(4,20)/1000)
                        VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
                    end
                end
            end
        end)
    end
end
