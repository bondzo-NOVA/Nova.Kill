-- Simple delta fallback + original sampling
local lastTime, frameCount = tick(), 0
local fpsSamples = {}
RunService.RenderStepped:Connect(function(delta)
    frameCount += 1
    local now = tick()
   
    -- Fallback counter (very reliable)
    if now - lastTime >= 1 then
        FPSLabel.Text = "FPS: " .. math.floor(frameCount / (now - lastTime) + 0.5)
        frameCount = 0
        lastTime = now
    end
   
    -- Original sampling (backup)
    table.insert(fpsSamples, now)
    while fpsSamples[1] and fpsSamples[1] < now - 1 do
        table.remove(fpsSamples, 1)
    end
    local count = #fpsSamples
    if count >= 2 then
        FPSLabel.Text = "FPS: " .. math.floor(count / (now - fpsSamples[1]) + 0.5)
    end
end)
